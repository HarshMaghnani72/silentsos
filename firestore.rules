rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ═══════════════════════════════════════════════════════════
    // USERS COLLECTION
    // ═══════════════════════════════════════════════════════════
    match /users/{userId} {
      // Users can read and write their own profile
      allow read, write: if isOwner(userId);
      
      // Validate user data structure on create
      allow create: if isOwner(userId) 
        && request.resource.data.keys().hasAll(['uid', 'phoneNumber', 'createdAt'])
        && request.resource.data.uid == userId;
      
      // Validate user data structure on update
      allow update: if isOwner(userId)
        && request.resource.data.uid == userId;
    }
    
    // ═══════════════════════════════════════════════════════════
    // EMERGENCY CONTACTS COLLECTION
    // ═══════════════════════════════════════════════════════════
    match /emergency_contacts/{contactId} {
      // Users can only access their own contacts
      allow read: if isAuthenticated() 
        && resource.data.userId == request.auth.uid;
      
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'name', 'phoneNumber', 'priority'])
        && request.resource.data.phoneNumber is string
        && request.resource.data.phoneNumber.size() >= 7
        && request.resource.data.name.size() > 0;
      
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }
    
    // ═══════════════════════════════════════════════════════════
    // SOS EVENTS COLLECTION
    // ═══════════════════════════════════════════════════════════
    match /sos_events/{eventId} {
      // Users can read their own SOS events
      allow read: if isAuthenticated() 
        && resource.data.userId == request.auth.uid;
      
      // Users can create SOS events for themselves
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'triggerType', 'status', 'startedAt'])
        && request.resource.data.status in ['ACTIVE', 'PENDING', 'ESCALATED']
        && request.resource.data.startedAt is number;
      
      // Users can update their own SOS events (for cancellation or status updates)
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      
      // Users cannot delete SOS events (for audit trail)
      allow delete: if false;
    }
    
    // ═══════════════════════════════════════════════════════════
    // LOCATION UPDATES COLLECTION
    // ═══════════════════════════════════════════════════════════
    match /location_updates/{updateId} {
      // Users can read location updates for their own SOS events
      allow read: if isAuthenticated()
        && exists(/databases/$(database)/documents/sos_events/$(resource.data.sosEventId))
        && get(/databases/$(database)/documents/sos_events/$(resource.data.sosEventId)).data.userId == request.auth.uid;
      
      // Users can create location updates for their own active SOS events
      allow create: if isAuthenticated()
        && exists(/databases/$(database)/documents/sos_events/$(request.resource.data.sosEventId))
        && get(/databases/$(database)/documents/sos_events/$(request.resource.data.sosEventId)).data.userId == request.auth.uid
        && get(/databases/$(database)/documents/sos_events/$(request.resource.data.sosEventId)).data.status in ['ACTIVE', 'ESCALATED']
        && request.resource.data.keys().hasAll(['sosEventId', 'latitude', 'longitude', 'timestamp'])
        && request.resource.data.latitude is number
        && request.resource.data.longitude is number
        && request.resource.data.latitude >= -90 && request.resource.data.latitude <= 90
        && request.resource.data.longitude >= -180 && request.resource.data.longitude <= 180;
      
      // Location updates cannot be modified or deleted (for audit trail)
      allow update, delete: if false;
    }

    match /notification_queue/{requestId} {
      // Users can create notification requests for themselves
      // We removed the exists() check on sos_events because it often fails due to
      // propagation latency when an event and its notifications are created in quick succession.
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'sosEventId', 'contactId', 'contactPhoneNumber', 'type', 'title', 'body', 'createdAt']);

      // Users can read their own notification requests
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      // Notification requests cannot be modified or deleted by the client
      allow update, delete: if false;
    }
    
    // ═══════════════════════════════════════════════════════════
    // DEFAULT DENY ALL
    // ═══════════════════════════════════════════════════════════
    // Any collection not explicitly defined above is denied by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
